.home-intro {
  margin-bottom: 28px;
}

.home-lead {
  max-width: 900px;
}

.chapter-nav {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 12px;
}

.chapter-pill {
  display: inline-flex;
  padding: 10px 16px;
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--deep);
  background: rgba(255,255,255,.35);
}

.chapter-pill:hover {
  border-color: var(--accent);
  color: var(--accent);
}

.chapter-section {
  margin-top: 40px;
  padding-top: 20px;
  border-top: 1px solid var(--line);
}

.chapter-header h2 {
  margin: 0 0 18px;
  font-size: 2rem;
}

.month-block {
  margin-top: 18px;
}

.month-title {
  margin-bottom: 14px;
  color: var(--deep);
  font-weight: 700;
  letter-spacing: .02em;
}

.day-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
  gap: 16px;
}

.day-card {
  display: block;
  padding: 18px;
  border: 1px solid var(--line);
  border-radius: 20px;
  background: rgba(255,255,255,.28);
  transition: transform .15s ease, border-color .15s ease, background .15s ease;
}

.day-card:hover {
  transform: translateY(-2px);
  border-color: var(--accent);
  background: rgba(255,255,255,.46);
}

.day-card-top {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 10px;
  color: var(--muted);
  font-size: .92rem;
}

.day-card h3 {
  margin: 0 0 8px;
  font-size: 1.18rem;
}

.day-card p {
  margin: 0;
  color: var(--muted);
  line-height: 1.7;
}

.day-pager {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 14px;
  align-items: stretch;
  margin-top: 34px;
  padding-top: 24px;
  border-top: 1px solid var(--line);
}

.pager-card {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 16px 18px;
  border: 1px solid var(--line);
  border-radius: 18px;
  background: rgba(255,255,255,.28);
  min-height: 84px;
}

.pager-card:hover {
  border-color: var(--accent);
}

.pager-card-empty {
  visibility: hidden;
}

.pager-label {
  font-size: .82rem;
  color: var(--muted);
}

.pager-home {
  align-self: center;
  padding: 10px 16px;
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--deep);
  white-space: nowrap;
}

.pager-home:hover {
  border-color: var(--accent);
  color: var(--accent);
}

@media (max-width: 900px) {
  .hero, .hero img {
    min-height: 55vh;
    height: 55vh;
  }

  .content {
    grid-template-columns: 1fr;
    gap: 26px;
  }

  .meta {
    position: static;
    border-right: 0;
    border-top: 1px solid var(--line);
    padding-right: 0;
    padding-top: 18px;
  }

  .day-grid {
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }

  .gallery-grid {
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 12px;
  }

  .gallery-grid .photo img {
    height: 160px !important;
  }

  .day-pager {
    grid-template-columns: 1fr;
  }

  .pager-card-empty {
    display: none;
  }

  .pager-home {
    justify-self: start;
  }
}

      @media (max-width: 900px) {
