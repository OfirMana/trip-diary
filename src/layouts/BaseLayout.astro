---
interface Props {
  title?: string;
  chapterTheme?: string;
}

const { title = 'Trip Diary', chapterTheme = 'default' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style is:global>
      :root {
  --bg: #edf1f4;
  --paper: #f7f4ee;
  --ink: #1d2b35;
  --muted: #5f6f7a;
  --line: rgba(88, 107, 120, 0.26);
  --accent: #69b7d6;
  --accent-warm: #c24f41;
  --deep: #102736;
  --max: 1120px;

  --surface: rgba(255,255,255,.44);
  --surface-strong: rgba(255,255,255,.66);
  --card-shadow: 0 20px 45px rgba(10, 26, 38, 0.12);
}

* { box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  margin: 0;
  color: var(--ink);
  font-family: "Heebo", system-ui, -apple-system, "Segoe UI", Arial, sans-serif;
  line-height: 1.9;
  text-align: right;
  background:
    radial-gradient(circle at top left, rgba(105,183,214,.20), transparent 30%),
    radial-gradient(circle at top right, rgba(194,79,65,.09), transparent 24%),
    linear-gradient(180deg, #dae5eb 0%, #eef3f5 45%, #f5f1e8 100%);
  background-attachment: fixed;
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  opacity: .15;
  z-index: -1;
  background-image:
    repeating-linear-gradient(0deg, rgba(255,255,255,.24) 0, rgba(255,255,255,.24) 1px, transparent 1px, transparent 3px);
}

a {
  color: inherit;
  text-decoration: none;
}

img {
  display: block;
  width: 100%;
  height: auto;
}

.site-header {
  width: min(calc(100vw - 34px), var(--max));
  margin: 22px auto 0;
  padding: 14px 0 6px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  font-size: 0.96rem;
  color: var(--muted);
}

.brand {
  font-weight: 800;
  color: var(--deep);
  letter-spacing: .02em;
}

.site-nav {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.site-nav a:hover {
  color: var(--accent);
}

.page {
  width: min(calc(100vw - 34px), var(--max));
  margin: 18px auto 72px;
}

.hero {
  position: relative;
  border-radius: 34px;
  overflow: hidden;
  min-height: 68vh;
  background: #0d1d27;
  box-shadow: 0 28px 58px rgba(12, 27, 38, 0.2);
  border: 1px solid rgba(255,255,255,.2);
}

.hero img {
  height: 68vh;
  object-fit: cover;
  object-position: center center;
}

.hero::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(5,16,24,0.1) 0%, rgba(7,20,28,0.22) 40%, rgba(7,20,28,0.74) 100%);
}

.hero-copy {
  position: absolute;
  inset: auto 0 0 0;
  z-index: 2;
  padding: 34px 34px 34px;
  color: white;
}

.eyebrow {
  letter-spacing: .1em;
  text-transform: uppercase;
  font-size: .86rem;
  opacity: .88;
  margin-bottom: 10px;
  font-weight: 800;
  color: #cbeefc;
}

h1, h2, h3 {
  font-family: "Noto Serif Hebrew", "David Libre", Georgia, "Times New Roman", serif;
  letter-spacing: .01em;
}

h1 {
  margin: 0;
  font-size: clamp(2.4rem, 5vw, 4.8rem);
  line-height: 0.98;
  max-width: 12ch;
  text-wrap: balance;
}

.sub {
  margin-top: 14px;
  max-width: 44rem;
  color: rgba(255,255,255,.94);
  font-size: 1.08rem;
}
.summary-panel {
  margin: 24px auto 30px;
  max-width: 760px;
  padding: 18px 22px;
  border-radius: 22px;
  border: 1px solid var(--line);
  background: linear-gradient(140deg, rgba(255,255,255,.62), rgba(255,255,255,.38));
  box-shadow: var(--card-shadow);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.summary-label {
  font-size: .78rem;
  text-transform: uppercase;
  letter-spacing: .12em;
  font-weight: 800;
  margin-bottom: 8px;
  color: var(--accent);
}

.summary-text {
  margin: 0;
  font-size: 1.08rem;
  line-height: 1.8;
  color: var(--ink);
}

.lead {
  margin: 32px auto 28px;
  max-width: 780px;
  font-family: Georgia, "Times New Roman", serif;
  font-size: clamp(1.14rem, 2vw, 1.42rem);
  color: #2a3944;
}

.divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--line) 12%, var(--line) 88%, transparent);
  margin: 0 0 30px;
}

.content {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 230px;
  gap: 44px;
  align-items: start;
}

.story {
  max-width: 780px;
}

.section-label {
  color: var(--deep);
  font-size: .82rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  font-weight: 800;
  margin-bottom: 12px;
  position: relative;
  padding-right: 18px;
}

.section-label::before {
  content: "";
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: linear-gradient(135deg, var(--accent), var(--accent-warm));
}

.story p {
  margin: 0 0 1.2em;
  font-size: 1.08rem;
}

.meta {
  color: var(--muted);
  font-size: .98rem;
  border-right: 1px solid var(--line);
  padding-right: 18px;
  position: sticky;
  top: 18px;
}

.meta-group {
  margin-bottom: 22px;
}

.meta-title {
  color: var(--deep);
  font-size: .76rem;
  text-transform: uppercase;
  letter-spacing: .1em;
  margin-bottom: 4px;
  font-weight: 800;
  opacity: .9;
}

.meta-value {
  color: var(--ink);
}

.gallery {
  margin-top: 36px;
  padding-top: 26px;
  border-top: 1px solid var(--line);
}

.gallery-grid {
  direction: ltr;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 14px;
  margin-top: 16px;
}

.gallery-grid .photo {
  border-radius: 18px;
  overflow: hidden;
  background: #d2dbe0;
  box-shadow: var(--card-shadow);
}

.gallery-grid .photo img {
  width: 100%;
  height: 220px;
  object-fit: cover;
  display: block;
}

.route-map-section {
  margin-top: 36px;
  padding-top: 26px;
  border-top: 1px solid var(--line);
}

.route-map {
  width: 100%;
  height: 420px;
  border-radius: 22px;
  overflow: hidden;
  background: #d2dbe0;
  margin-top: 16px;
  box-shadow: var(--card-shadow);
}

.home-intro {
  margin-bottom: 34px;
}

.home-hero {
  position: relative;
  margin-bottom: 30px;
  border-radius: 30px;
  overflow: hidden;
  min-height: 48vh;
  display: flex;
  align-items: end;
  border: 1px solid rgba(255,255,255,.24);
  box-shadow: var(--card-shadow);
  background:
    radial-gradient(circle at 18% 18%, rgba(105,183,214,.4), transparent 33%),
    radial-gradient(circle at 82% 22%, rgba(194,79,65,.24), transparent 24%),
    linear-gradient(130deg, #101f2c 0%, #172f3f 48%, #213949 100%);
}

.home-hero::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(4,10,16,.05) 0%, rgba(8,16,22,.62) 100%);
}

.home-hero-copy {
  position: relative;
  z-index: 1;
  color: #f5fbff;
  padding: 28px 28px 30px;
}

.home-hero-copy h1 {
  font-size: clamp(2rem, 5.4vw, 4.2rem);
  margin: 0;
  max-width: 12ch;
}

.home-hero-copy .sub {
  margin-top: 14px;
  max-width: 50ch;
}

.home-lead {
  max-width: 920px;
}

.chapter-nav {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 12px;
}

.chapter-pill {
  display: inline-flex;
  padding: 10px 16px;
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--deep);
  background: var(--surface);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  box-shadow: var(--card-shadow);
}

.chapter-pill:hover {
  border-color: var(--accent);
  color: var(--accent);
}

.chapter-section {
  margin-top: 40px;
  padding: 26px 20px 6px;
  border: 1px solid var(--line);
  border-radius: 30px;
  box-shadow: var(--card-shadow);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.chapter-theme-iceland {
  background:
    linear-gradient(180deg, rgba(8, 26, 38, 0.82), rgba(8, 26, 38, 0.42) 80%);
}

.chapter-theme-norway {
  background:
    linear-gradient(180deg, rgba(56, 98, 80, 0.20), rgba(255,255,255,0) 72%);
}

.chapter-theme-eu {
  background:
    linear-gradient(180deg, rgba(195,135,61,.16), rgba(255,255,255,0) 72%);
}

.chapter-header h2 {
  margin: 0 0 18px;
  font-size: 2rem;
}

.month-block {
  margin-top: 18px;
}

.month-title {
  margin-bottom: 14px;
  color: var(--deep);
  font-weight: 800;
  letter-spacing: .02em;
}

.day-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
  gap: 16px;
}

.day-card {
  display: block;
  padding: 18px;
  border: 1px solid var(--line);
  border-radius: 22px;
  background: var(--surface);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: var(--card-shadow);
  transition: transform .18s ease, border-color .18s ease, background .18s ease, box-shadow .18s ease;
}

.day-card:hover {
  transform: translateY(-4px);
  border-color: var(--accent);
  background: var(--surface-strong);
  box-shadow: 0 24px 50px rgba(10, 26, 38, 0.16);
}

.day-card-top {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 10px;
  color: var(--muted);
  font-size: .92rem;
}

.day-card h3 {
  margin: 0 0 8px;
  font-size: 1.18rem;
}

.day-location {
  display: inline-flex;
  margin-bottom: 8px;
  padding: 3px 10px;
  border-radius: 999px;
  background: rgba(105,183,214,.16);
  color: var(--deep);
  font-size: .82rem;
  line-height: 1.5;
}

.day-card p {
  margin: 0;
  color: var(--muted);
  line-height: 1.7;
}

.day-pager {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 14px;
  align-items: stretch;
  margin-top: 34px;
  padding-top: 24px;
  border-top: 1px solid var(--line);
}

.pager-card {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 16px 18px;
  border: 1px solid var(--line);
  border-radius: 18px;
  background: var(--surface);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  min-height: 84px;
  box-shadow: var(--card-shadow);
}

.pager-card:hover {
  border-color: var(--accent);
}

.pager-card-empty {
  visibility: hidden;
}

.pager-label {
  font-size: .82rem;
  color: var(--muted);
}

.pager-home {
  align-self: center;
  padding: 10px 16px;
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--deep);
  white-space: nowrap;
  background: var(--surface);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.pager-home:hover {
  border-color: var(--accent);
  color: var(--accent);
}

.hero-route {
  display: inline-flex;
  margin-top: 14px;
  margin-bottom: 0;
  border-radius: 999px;
  padding: 4px 12px;
  font-size: .96rem;
  background: rgba(255,255,255,.18);
}

body.theme-iceland {
  --ink: #e7f2f8;
  --muted: #a8bfcc;
  --line: rgba(126, 201, 232, 0.18);
  --accent: #8ddcff;
  --accent-warm: #d65b4b;
  --deep: #eff9fe;
  --surface: rgba(9, 24, 34, 0.62);
  --surface-strong: rgba(9, 24, 34, 0.78);
  --card-shadow: 0 20px 44px rgba(4, 13, 20, 0.28);

  background:
    radial-gradient(circle at 14% 0%, rgba(126, 201, 232, 0.22), transparent 24%),
    radial-gradient(circle at 86% 8%, rgba(214, 91, 75, 0.10), transparent 18%),
    linear-gradient(180deg, #07121a 0%, #0b1b26 36%, #102634 100%);
}

body.theme-iceland .site-header,
body.theme-iceland .site-nav {
  color: #cfe5ef;
}

body.theme-iceland .brand {
  color: #f2fbff;
}
body.theme-iceland .summary-panel {
  background:
    linear-gradient(
      135deg,
      rgba(9, 24, 34, 0.82),
      rgba(15, 40, 56, 0.74)
    ),
    radial-gradient(circle at 92% 18%, rgba(214, 91, 75, 0.14), transparent 18%);
  border: 1px solid rgba(126, 201, 232, 0.18);
}

body.theme-iceland .summary-label {
  color: #8ddcff;
}

body.theme-iceland .summary-text {
  color: #ecf7fc;
}

body.theme-iceland .lead,
body.theme-iceland .story p,
body.theme-iceland .meta-value {
  color: #e4f1f7;
}

body.theme-iceland .section-label,
body.theme-iceland .meta-title,
body.theme-iceland .eyebrow,
body.theme-iceland .month-title {
  color: #8ddcff;
}

body.theme-iceland .day-location,
body.theme-iceland .hero-route {
  background: rgba(126, 201, 232, 0.16);
  color: #d9f1fc;
}

body.theme-iceland .divider {
  background:
    linear-gradient(
      90deg,
      transparent,
      rgba(126, 201, 232, 0.34) 25%,
      rgba(214, 91, 75, 0.18) 75%,
      transparent
    );
}

body.theme-iceland .meta,
body.theme-iceland .gallery,
body.theme-iceland .route-map-section,
body.theme-iceland .day-pager,
body.theme-iceland .chapter-section {
  border-color: rgba(126, 201, 232, 0.16);
}

body.theme-iceland .day-card,
body.theme-iceland .pager-card,
body.theme-iceland .pager-home,
body.theme-iceland .chapter-pill,
body.theme-iceland .gallery-grid .photo,
body.theme-iceland .route-map {
  background: var(--surface);
  border: 1px solid rgba(126, 201, 232, 0.14);
  box-shadow: var(--card-shadow);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}

body.theme-iceland .day-card:hover,
body.theme-iceland .pager-card:hover,
body.theme-iceland .chapter-pill:hover,
body.theme-iceland .pager-home:hover {
  background: var(--surface-strong);
  border-color: rgba(126, 201, 232, 0.30);
}

body.theme-iceland .day-card p,
body.theme-iceland .day-card-top,
body.theme-iceland .pager-label {
  color: #b7ccd8;
}

body.theme-iceland .hero {
  border: 1px solid rgba(126, 201, 232, 0.12);
  box-shadow: 0 22px 56px rgba(4, 13, 20, 0.34);
}

body.theme-iceland .hero::after {
  background:
    radial-gradient(circle at 72% 14%, rgba(126, 201, 232, 0.16), transparent 22%),
    radial-gradient(circle at 87% 18%, rgba(214, 91, 75, 0.09), transparent 15%),
    linear-gradient(180deg, rgba(6,16,24,0.18) 0%, rgba(7,20,28,0.26) 44%, rgba(7,20,28,0.72) 100%);
}

body.theme-iceland h1 {
  color: #ffffff;
  text-shadow: 0 10px 28px rgba(6, 16, 24, 0.34);
}

body.theme-iceland .sub {
  color: rgba(237, 247, 252, 0.95);
}

body.theme-iceland .chapter-theme-iceland {
  background:
    linear-gradient(180deg, rgba(9, 24, 34, 0.76), rgba(9, 24, 34, 0.32) 80%);
  border: 1px solid rgba(126, 201, 232, 0.12);
  box-shadow: var(--card-shadow);
}

body.theme-norway {
  --ink: #1d2c22;
  --muted: #5d6f66;
  --line: rgba(90, 120, 102, 0.28);
  --accent: #3d8c6b;
  --deep: #214a3d;
  --surface: rgba(255,255,255,.22);
  --surface-strong: rgba(255,255,255,.32);
  --card-shadow: 0 18px 36px rgba(26, 51, 40, 0.12);
  background:
    radial-gradient(circle at top left, rgba(122,176,154,.22), transparent 30%),
    radial-gradient(circle at top right, rgba(177,48,48,.08), transparent 24%),
    linear-gradient(180deg, #e7efe9 0%, #f4f7f3 100%);
}

body.theme-norway .hero::after {
  background: linear-gradient(180deg, rgba(10,22,17,0.10) 0%, rgba(10,22,17,0.18) 46%, rgba(10,22,17,0.58) 100%);
}

body.theme-norway .day-location,
body.theme-norway .hero-route {
  background: rgba(61, 140, 107, 0.16);
}

body.theme-eu {
  --ink: #2c251f;
  --muted: #73675c;
  --line: rgba(138, 118, 94, 0.25);
  --accent: #c3873d;
  --deep: #5d4631;
  --surface: rgba(255,255,255,.24);
  --surface-strong: rgba(255,255,255,.34);
  --card-shadow: 0 18px 36px rgba(58, 45, 30, 0.10);
  background:
    radial-gradient(circle at top left, rgba(230,191,120,.18), transparent 30%),
    radial-gradient(circle at top right, rgba(94,121,153,.14), transparent 26%),
    linear-gradient(180deg, #f2ece2 0%, #f8f3ea 100%);
}

body.theme-eu .hero::after {
  background: linear-gradient(180deg, rgba(20,17,14,0.10) 0%, rgba(20,17,14,0.20) 46%, rgba(20,17,14,0.58) 100%);
}

body.theme-eu .day-location,
body.theme-eu .hero-route {
  background: rgba(195, 135, 61, 0.18);
}

@media (max-width: 900px) {
  .site-header {
    margin-top: 14px;
  }

  .hero,
  .hero img {
    min-height: 56vh;
    height: 56vh;
  }

  .home-hero {
    min-height: 42vh;
  }

  .home-hero-copy {
    padding: 24px 20px;
  }

  .content {
    grid-template-columns: 1fr;
    gap: 26px;
  }

  .meta {
    position: static;
    border-right: 0;
    border-top: 1px solid var(--line);
    padding-right: 0;
    padding-top: 18px;
  }

  .day-grid {
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }

  .gallery-grid {
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 12px;
  }

  .gallery-grid .photo img {
    height: 160px;
  }

  .route-map {
    height: 320px;
  }

  .day-pager {
    grid-template-columns: 1fr;
  }

  .pager-card-empty {
    display: none;
  }

  .pager-home {
    justify-self: start;
  }
}
    </style>
  </head>
  <body class={`theme-${chapterTheme}`}>
    <header class="site-header">
      <nav class="site-nav">
        <a href={base}>דף הבית</a>
      </nav>
      <div class="brand">Trip Diary</div>
    </header>
    <slot />
  </body>
</html>
