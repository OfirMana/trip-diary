---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const slugifyChapter = (value) =>
  value.toLowerCase().replace(/&/g, 'and').replace(/\s+/g, '-');

const chapterCopy = {
  iceland: {
    kicker: 'Land of fire & ice',
    text: 'הכניסה למסע: קרח, רוח, גיאותרמיה, כבישים שחורים ונופים שנראים לא סבירים.',
  },
  norway: {
    kicker: 'Fjords & green light',
    text: 'מעבר לאווירה ירוקה יותר — פיורדים, גשם, יערות והתרחבות איטית של הדרך.',
  },
  eu: {
    kicker: 'Road mode',
    text: 'המסע בתנועה: טרמפים, ערים, גבולות, מפגשים וסיפור שהולך ונפתח תוך כדי תזוזה.',
  },
  default: {
    kicker: 'Chapter',
    text: 'חלק נוסף במסע.',
  },
};

const allDays = (await getCollection('days')).sort(
  (a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
);

const monthFormatter = new Intl.DateTimeFormat('he-IL', {
  month: 'long',
  year: 'numeric',
});

const shortDateFormatter = new Intl.DateTimeFormat('he-IL', {
  day: '2-digit',
  month: '2-digit',
});

const normalizedDays = allDays.map((day, index) => {
  const dateObj = new Date(day.data.date);
  return {
    ...day,
    tripIndex: index + 1,
    chapter: day.data.chapter ?? 'General',
    theme: day.data.chapterTheme ?? 'default',
    chapterSlug: slugifyChapter(day.data.chapter ?? 'General'),
    monthKey: `${dateObj.getFullYear()}-${String(dateObj.getMonth() + 1).padStart(2, '0')}`,
    monthLabel: monthFormatter.format(dateObj),
    shortDate: shortDateFormatter.format(dateObj),
  };
});

const chapterMap = new Map();
const monthMap = new Map();

for (const day of normalizedDays) {
  if (!chapterMap.has(day.chapter)) {
    chapterMap.set(day.chapter, {
      chapterName: day.chapter,
      chapterSlug: day.chapterSlug,
      theme: day.theme,
      hero: day.data.hero,
      days: [],
    });
  }

  chapterMap.get(day.chapter).days.push(day);

  if (!monthMap.has(day.monthKey)) {
    monthMap.set(day.monthKey, {
      label: day.monthLabel,
      days: [],
    });
  }

  monthMap.get(day.monthKey).days.push(day);
}

const chapters = [...chapterMap.values()].map((chapter) => {
  const firstDay = chapter.days[0];
  const lastDay = chapter.days[chapter.days.length - 1];
  const copy = chapterCopy[chapter.theme] ?? chapterCopy.default;

  return {
    ...chapter,
    daysCount: chapter.days.length,
    firstDate: firstDay.shortDate,
    lastDate: lastDay.shortDate,
    kicker: copy.kicker,
    text: copy.text,
  };
});

const months = [...monthMap.values()];

const totalDays = normalizedDays.length;
const startDay = normalizedDays[0];
const endDay = normalizedDays[normalizedDays.length - 1];
---

<BaseLayout title="Trip Diary">
  <main class="page">
    <section class="home-masthead">
      <div class="home-masthead-copy">
        <div class="eyebrow">Summer journey journal</div>
        <h1>יומן מסע חי, מסודר לפי פרקים וימים</h1>
        <p class="sub">
          האתר הזה הוא גם שער למסע וגם ארכיון מסודר שלו — אפשר להיכנס דרך הפרקים,
          או פשוט לדפדף דרך יומן הימים כולו.
        </p>

        <div class="trip-stats">
          <div class="trip-stat">
            <span class="trip-stat-value">{totalDays}</span>
            <span class="trip-stat-label">ימים</span>
          </div>
          <div class="trip-stat">
            <span class="trip-stat-value">{chapters.length}</span>
            <span class="trip-stat-label">פרקים</span>
          </div>
          <div class="trip-stat">
            <span class="trip-stat-value">{startDay?.shortDate}</span>
            <span class="trip-stat-label">התחלה</span>
          </div>
          <div class="trip-stat">
            <span class="trip-stat-value">{endDay?.shortDate}</span>
            <span class="trip-stat-label">סיום</span>
          </div>
        </div>
      </div>

      <div class="home-masthead-side">
        <div class="home-note-card">
          <div class="section-label">איך נכנסים</div>
          <p>
            אפשר להתחיל מפרק שלם ולהיכנס לאווירה, או לקפוץ ישירות ליום מסוים דרך לוח המסע.
          </p>
        </div>
      </div>
    </section>

    <section class="chapter-gates-section">
      <div class="section-label">פרקי המסע</div>

      <div class="chapter-gates">
        {chapters.map((chapter) => (
          <a
            class={`chapter-gate gate-theme-${chapter.theme}`}
            href={`${base}/chapter/${chapter.chapterSlug}/`}
          >
            <img
              src={`${base}/images/${chapter.hero}`}
              alt={chapter.chapterName}
            />
            <div class="chapter-gate-copy">
              <div class="gate-kicker">{chapter.kicker}</div>
              <h2>{chapter.chapterName}</h2>
              <p>{chapter.text}</p>

              <div class="gate-meta">
                <span>{chapter.daysCount} ימים</span>
                <span>{chapter.firstDate} → {chapter.lastDate}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="trip-calendar-section">
      <div class="section-label">יומן הימים</div>

      {months.map((month) => (
        <section class="calendar-month">
          <div class="calendar-month-title">{month.label}</div>

          <div class="calendar-track">
            {month.days.map((day) => (
              <a
                class={`calendar-day calendar-day-${day.theme}`}
                href={`${base}/day/${day.id}/`}
              >
                <span class="calendar-day-top">
                  <span>יום {day.tripIndex}</span>
                  <span>{day.shortDate}</span>
                </span>

                <strong>{day.data.title}</strong>

                {day.data.chapter && (
                  <span class="calendar-day-chapter">{day.data.chapter}</span>
                )}
              </a>
            ))}
          </div>
        </section>
      ))}
    </section>
  </main>
</BaseLayout>