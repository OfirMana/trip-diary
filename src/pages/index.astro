---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const days = (await getCollection('days')).sort(
  (a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Trip Diary">
  <main class="page">
    <section>
      <div class="lead" style="max-width: 860px; margin-top: 16px;">
        זה האתר של יומן המסע. הרעיון פשוט:
        מעצבים פעם אחת, ואז כל יום נכנס לאותה תבנית.
        לא בונים 70 עמודים ידנית — מוסיפים 70 קבצי תוכן.
      </div>

      <div class="divider"></div>

      <div class="home-list">
        {days.map((day, index) => (
          <a class="day-link" href={`${base}day/${day.id}/`}>
            <h2>יום {index + 1} — {day.data.title}</h2>
            <div class="summary">{day.data.summary}</div>
            <span class="button-like">ליום המלא</span>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
